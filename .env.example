# ── Supabase (PostgreSQL + Auth) ──
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Session secrets (REQUIRED in production — generate with: openssl rand -base64 32) ──
SESSION_SECRET=replace-with-32+char-random-string

# ── Cloudinary (unsigned uploads from admin gallery + quote form) ──
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=avrkqnms
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_FOLDER=86Connect-cars/
# Server-side only (signed uploads, deletions, admin API) — NOT exposed to browser
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Upstash Redis (rate limiting for auth + form submissions) ──
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Public site URL (used for sitemap, robots, OG tags, email links) ──
NEXT_PUBLIC_SITE_URL=https://cars.the86connect.com

# ── Resend (email notifications) ──
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=cars@the86connect.com
NOTIFY_EMAIL=admin@the86connect.com

# ── Main admin panel forwarding (Render backend URL, NOT frontend) ──
MAIN_ADMIN_CAR_QUOTE_API=https://api.the86connect.com/api/car-quote-webhook
# Shared secret for webhook auth between cars app and main admin panel
# Must match CARS_APP_WEBHOOK_SECRET on the main admin panel
WEBHOOK_SECRET=replace-with-shared-secret-string